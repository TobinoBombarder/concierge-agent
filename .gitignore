# --- Secrets (capstone rules penalize committed secrets — NEVER commit these) ---
# NOTE: .gitignore treats a trailing "# ..." as part of the pattern, so keep
# comments on their own lines — never inline after a filename.
.env
# Google OAuth client secrets (downloaded from Cloud Console)
credentials.json
# cached OAuth user token after first consent
token.json
*.pem
*.key

# --- Python ---
__pycache__/
*.py[cod]
.venv/
venv/
env/
*.egg-info/
.pytest_cache/

# --- OS / editor ---
.DS_Store
.vscode/
.idea/

# Copy this file to the local env file and fill in real values.
# NEVER commit the real one (it is gitignored). Only GEMINI_API_KEY is required;
# everything else has a sensible default and can be left unset.

# --- Gemini (Google AI Studio) — REQUIRED ---
# Get a key at https://aistudio.google.com/apikey
# The code also accepts GOOGLE_API_KEY; if only GEMINI_API_KEY is set it is
# mirrored automatically (non-Vertex AI Studio mode).
GEMINI_API_KEY=your-gemini-api-key-here

# Model id. Default is gemini-2.5-flash (free-tier quota works for it; 2.0-flash
# may be limit:0 on some AI Studio keys). Read by orchestrator + prioritizer.
CONCIERGE_MODEL=gemini-2.5-flash

# --- Agent identity (optional) ---
# Display name + opening greeting. Single source of truth for the API /greeting
# endpoint, the demo page, and the agent's self-introduction.
CONCIERGE_AGENT_NAME=José
# CONCIERGE_GREETING=Hey there, I'm José — how can I help you today?

# --- API service / CORS (optional) ---
# Comma-separated browser origins allowed to call /chat. Include the Vercel demo
# page origin and the life-os-prime dashboard origin in production.
CONCIERGE_ALLOWED_ORIGINS=http://localhost:3000

# --- Rate limiting for the public demo (optional) ---
# Protects the free-tier Gemini quota. Per-IP burst + global cap, per window secs.
CONCIERGE_RATE_PER_IP=10
CONCIERGE_RATE_PER_IP_WINDOW=60
CONCIERGE_RATE_GLOBAL=60
CONCIERGE_RATE_GLOBAL_WINDOW=60

# --- Google Calendar OAuth (read-only, optional) ---
# The agent degrades gracefully without these — it just uses tasks.json only.
# Path to the OAuth client secrets JSON (Desktop app) from Google Cloud Console.
GOOGLE_OAUTH_CLIENT_FILE=credentials.json
# Where the cached user token is stored after first consent (gitignored).
GOOGLE_OAUTH_TOKEN_FILE=token.json
